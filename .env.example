# Primary model: strongest conversation model
# Recommended free hosted option: Groq Llama 3.3 70B
PRIMARY_API_BASE=https://api.groq.com/openai/v1
PRIMARY_API_KEY=your_primary_free_api_key_here
PRIMARY_MODEL=llama-3.3-70b-versatile

# Fallback model: cheaper/faster backup if primary is unavailable
# Recommended free hosted option: Groq Llama 3.1 8B
FALLBACK_API_BASE=https://api.groq.com/openai/v1
FALLBACK_API_KEY=your_fallback_free_api_key_here
FALLBACK_MODEL=llama-3.1-8b-instant

# Optional: cap assistant reply length (tokens) for concise answers — default 768
# MAX_OUTPUT_TOKENS=768

# Optional: max characters per user message before calling the model — default 4000
# MAX_USER_INPUT_CHARS=4000

# Optional: max messages (user + assistant each count as 1) passed to the LLM — default 40.
# Older turns stay visible in the chat UI but are omitted from model context. Use 0 for no limit.
# MAX_LLM_CONTEXT_MESSAGES=40

# Optional local Ollama compatibility for PRIMARY only (omit PRIMARY_API_BASE)
# Code accepts OPENAI_API_BASE or OLLAMA_BASE_URL as the local OpenAI-compatible URL
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL_NAME=llama3.1:8b
# OPENAI_API_KEY=not-needed-for-local
